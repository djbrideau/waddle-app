rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read/write own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Dojos: students can read if enrolled, teachers can read/write their own
    match /dojos/{dojoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.teacherId == request.auth.uid;
    }

    // Question Sets: anyone authenticated can read, authors can write
    match /questionSets/{setId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    // Quiz Results: users can create their own, read their own
    match /quizResults/{resultId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Global State: anyone can read, only admins write (enforced client-side for now)
    match /globalState/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
